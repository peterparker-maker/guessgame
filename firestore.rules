// ============================================================
// Firestore 安全規則
// ------------------------------------------------------------
// 用途：限制「誰可以讀寫」你的猜猜看資料。
// 使用方式：
//   1. 到 Firebase Console -> Firestore Database -> 規則（Rules）分頁
//   2. 把下面整段貼上去，覆蓋掉原本的內容
//   3. 按「發布（Publish）」
//
// 這個版本是「任何知道你網站網址的人都能讀寫」，
// 等同於現在 artifact 共享儲存的安全等級，但資料是存在你自己
// 的 Firebase 帳號底下，你可以隨時關閉、清空、改規則。
//
// 如果你想要更嚴格（例如要求輸入密碼才能用整個網站），
// 之後可以再升級成搭配 Firebase Authentication 的版本，
// 跟我說一聲，我再幫你加。
// ============================================================

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /questions/{questionId} {
      allow read, write: if true;
    }
  }
}
